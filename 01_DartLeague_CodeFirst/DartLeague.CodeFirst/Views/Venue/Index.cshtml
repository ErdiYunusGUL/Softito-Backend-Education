@model IEnumerable<DartLeague.CodeFirst.Models.Venue>
@{ ViewData["Title"] = "Venues & Home Teams"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-info fw-bold"><i class="bi bi-geo-alt-fill"></i> Venues</h2>
    @if (User.IsInRole("Admin")) {
        <a asp-action="Create" class="btn btn-info text-dark shadow-sm"><i class="bi bi-plus-lg"></i> Add Venue</a>
    }
</div>

<div class="row g-4">
    @foreach (var venue in Model) {
        <div class="col-12">
            <div class="glass-card d-flex flex-column flex-md-row align-items-center align-items-md-start p-4 mb-3 position-relative" style="background: rgba(255, 255, 255, 0.05); border-left: 5px solid #0dcaf0;">
                
                <!-- Left Side: Venue Info & Teams -->
                <div class="flex-grow-1 w-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h3 class="fw-bold mb-0">@venue.Name</h3>
                        
                        @if (User.IsInRole("Admin")) {
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark glass-card">
                                    <li><a class="dropdown-item text-warning" asp-action="Edit" asp-route-id="@venue.Id">Edit</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@venue.Id" onclick="return confirm('Are you sure?');">Delete</a></li>
                                </ul>
                            </div>
                        }
                    </div>
                    
                    <p class="text-muted fw-semibold mb-3">Home Teams</p>
                    
                    <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                        @if(venue.HomeTeams != null && venue.HomeTeams.Any()) {
                            foreach (var team in venue.HomeTeams) {
                                <li class="d-flex align-items-center">
                                    @if(!string.IsNullOrEmpty(team.LogoUrl)) {
                                        <img src="@team.LogoUrl" alt="@team.Name Logo" class="rounded-circle me-3 border border-secondary" style="width: 32px; height: 32px; object-fit: cover;" />
                                    } else {
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px;">
                                            <i class="bi bi-shield-shaded"></i>
                                        </div>
                                    }
                                    <span class="fs-5 text-light">@team.Name</span>
                                </li>
                            }
                        } else {
                            <li class="text-muted fst-italic">No home teams yet.</li>
                        }
                    </ul>
                </div>
                
                <!-- Right Side: Venue Logo -->
                <div class="ms-md-5 mt-4 mt-md-0 d-flex justify-content-center align-items-center" style="min-width: 200px;">
                    @if(!string.IsNullOrEmpty(venue.LogoUrl)) {
                        <img src="@venue.LogoUrl" alt="@venue.Name Logo" class="img-fluid rounded shadow-sm bg-white p-2" style="max-height: 150px; max-width: 200px; object-fit: contain;" />
                    } else {
                        <div class="bg-dark bg-opacity-50 border border-secondary rounded d-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                            <i class="bi bi-image text-muted display-4"></i>
                        </div>
                    }
                </div>
                
            </div>
        </div>
    }
</div>
