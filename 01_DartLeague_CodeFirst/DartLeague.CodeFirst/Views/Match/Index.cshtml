@model IEnumerable<DartLeague.CodeFirst.Models.Match>
@{ ViewData["Title"] = "Fixtures"; }

<style>
    .match-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .match-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3) !important;
    }
    .score-badge {
        font-size: 1.25rem;
        padding: 0.5rem 1.5rem;
        letter-spacing: 2px;
    }
    .points-pill {
        font-size: 0.75rem;
        padding: 0.25rem 0.6rem;
    }
    .nav-pills .nav-link.active {
        background-color: var(--bs-primary);
        box-shadow: 0 4px 10px rgba(var(--bs-primary-rgb), 0.4);
        font-weight: bold;
    }
    .nav-pills .nav-link {
        color: var(--bs-light);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .nav-pills .nav-link:hover:not(.active) {
        background-color: rgba(255,255,255,0.05);
    }
    .w-35 { width: 35%; }
    .w-30 { width: 30%; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-calendar-week"></i> League Fixtures</h2>
    @if (User.IsInRole("Admin")) {
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg"></i> Add Match
        </a>
    }
</div>

@{
    var groupedByCategory = Model
        .GroupBy(m => m.HomeTeam?.Category?.Name ?? "Uncategorized")
        .OrderBy(g => g.Key)
        .ToList();
}

@if(!groupedByCategory.Any())
{
    <div class="alert alert-info glass-card text-center py-5">
        <i class="bi bi-info-circle fs-1 d-block mb-3"></i>
        <h4>No fixtures available yet.</h4>
        <p>Check back later or add a new match if you are an administrator.</p>
    </div>
}

@foreach (var categoryGroup in groupedByCategory)
{
    <div class="mb-5">
        <h3 class="text-warning mb-3 border-bottom border-secondary pb-2"><i class="bi bi-trophy-fill"></i> @categoryGroup.Key</h3>
        
        @{
            var groupedByWeek = categoryGroup
                .GroupBy(m => m.Week)
                .OrderBy(g => g.Key)
                .ToList();
            var categoryIdSafe = categoryGroup.Key.Replace(" ", "");
        }

        <ul class="nav nav-pills mb-4 gap-2" id="pills-tab-@categoryIdSafe" role="tablist">
            @foreach (var weekGroup in groupedByWeek)
            {
                var isFirst = weekGroup.Key == groupedByWeek.First().Key;
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(isFirst ? "active" : "") rounded-pill px-4" 
                            id="pills-week-@(categoryIdSafe)-@(weekGroup.Key)-tab" 
                            data-bs-toggle="pill" 
                            data-bs-target="#pills-week-@(categoryIdSafe)-@(weekGroup.Key)" 
                            type="button" role="tab">
                        Week @weekGroup.Key
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content" id="pills-tabContent-@categoryIdSafe">
            @foreach (var weekGroup in groupedByWeek)
            {
                var isFirst = weekGroup.Key == groupedByWeek.First().Key;
                <div class="tab-pane fade @(isFirst ? "show active" : "")" 
                     id="pills-week-@(categoryIdSafe)-@(weekGroup.Key)" 
                     role="tabpanel" tabindex="0">
                    
                    <div class="row">
                        @foreach (var item in weekGroup.OrderBy(m => m.MatchDate))
                        {
                            var homeScore = item.HomeTeamScore ?? 0;
                            var awayScore = item.AwayTeamScore ?? 0;
                            var homePoints = item.IsPlayed ? (homeScore > awayScore ? 3 : (homeScore == awayScore ? 1 : 0)) : 0;
                            var awayPoints = item.IsPlayed ? (awayScore > homeScore ? 3 : (homeScore == awayScore ? 1 : 0)) : 0;

                            <div class="col-lg-6 mb-4">
                                <div class="glass-card match-card h-100 p-4 border-start border-4 @(item.IsPlayed ? "border-success" : "border-primary")">
                                    <div class="d-flex justify-content-between text-muted small mb-3">
                                        <span class="text-light"><i class="bi bi-calendar-event"></i> @item.MatchDate.ToString("dd MMM yyyy HH:mm")</span>
                                        <span class="text-light"><i class="bi bi-geo-alt-fill text-danger"></i> @(item.Venue?.Name ?? "TBD")</span>
                                    </div>
                                    
                                    <div class="d-flex justify-content-between align-items-center">
                                        <!-- Home Team -->
                                        <div class="w-35 text-end">
                                            <h5 class="mb-1 fw-bold @(item.IsPlayed && homePoints == 3 ? "text-success" : "")">
                                                @item.HomeTeam?.Name
                                            </h5>
                                            @if(item.IsPlayed && homePoints > 0)
                                            {
                                                <span class="badge rounded-pill bg-success points-pill">+@homePoints Pts</span>
                                            }
                                        </div>
                                        
                                        <!-- Score Area -->
                                        <div class="w-30 text-center px-1">
                                            @if (item.IsPlayed) {
                                                <div class="bg-dark text-white rounded-pill score-badge d-inline-block shadow border border-secondary">
                                                    <span class="@(homeScore > awayScore ? "text-success" : "")">@item.HomeTeamScore</span> - <span class="@(awayScore > homeScore ? "text-success" : "")">@item.AwayTeamScore</span>
                                                </div>
                                                <div class="small text-muted mt-1" style="font-size:0.7rem;">FULL TIME</div>
                                            } else {
                                                <div class="bg-secondary bg-opacity-25 text-white rounded-pill px-3 py-2 fs-6 d-inline-block shadow-sm">
                                                    VS
                                                </div>
                                            }
                                        </div>
                                        
                                        <!-- Away Team -->
                                        <div class="w-35 text-start">
                                            <h5 class="mb-1 fw-bold @(item.IsPlayed && awayPoints == 3 ? "text-success" : "")">
                                                @item.AwayTeam?.Name
                                            </h5>
                                            @if(item.IsPlayed && awayPoints > 0)
                                            {
                                                <span class="badge rounded-pill bg-success points-pill">+@awayPoints Pts</span>
                                            }
                                        </div>
                                    </div>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="text-center mt-3 pt-3 border-top border-secondary border-opacity-25 d-flex justify-content-center gap-2">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3"><i class="bi bi-info-circle"></i> Details</a>
                                            <a asp-action="EditGames" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3"><i class="bi bi-controller"></i> Edit Games</a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3"><i class="bi bi-pencil"></i> Edit Match</a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center mt-3 pt-3 border-top border-secondary border-opacity-25">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3"><i class="bi bi-info-circle"></i> Match Details</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
