@model IEnumerable<AdvancedGameStore.Models.SupportTicket>
@{
    ViewData["Title"] = "Açık Talepler";
}

<div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
    <div>
        <h1 class="text-3xl font-bold text-support-text mb-1">Bekleyen Talepler</h1>
        <p class="text-support-muted">Müşterilerden gelen ve henüz çözülmemiş destek talepleri.</p>
    </div>
    
    <div class="flex items-center bg-white border border-support-border rounded-full px-4 py-2 shadow-sm w-full md:w-80 focus-within:ring-2 focus-within:ring-support-primary/20 focus-within:border-support-primary transition-all">
        <i class="fa-solid fa-search text-support-muted mr-2"></i>
        <input type="text" placeholder="Talep ara (ID, Müşteri, Konu)..." class="bg-transparent border-none outline-none text-sm w-full text-support-text placeholder-support-muted" />
    </div>
</div>

<div class="grid grid-cols-1 gap-4">
    @if (!Model.Any())
    {
        <div class="bg-white border border-support-border rounded-2xl p-12 text-center shadow-sm">
            <div class="w-20 h-20 bg-support-secondary text-support-primary rounded-full flex items-center justify-center mx-auto mb-4 text-4xl shadow-inner">
                <i class="fa-regular fa-face-smile-beam"></i>
            </div>
            <h3 class="text-2xl font-bold text-support-text mb-2">Harika! Bekleyen talep yok.</h3>
            <p class="text-support-muted text-lg">Tüm müşterilerin sorunları çözüldü, arkana yaslan ve kahveni yudumla.</p>
        </div>
    }
    else
    {
        @foreach (var ticket in Model)
        {
            <div class="bg-white border border-support-border hover:border-support-primary/50 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col md:flex-row gap-4 md:items-center justify-between group cursor-pointer">
                
                <div class="flex items-start gap-5 flex-grow">
                    <div class="w-14 h-14 rounded-2xl bg-amber-50 text-amber-500 border border-amber-100 flex items-center justify-center flex-shrink-0 text-2xl group-hover:scale-110 group-hover:rotate-3 transition-transform shadow-sm">
                        <i class="fa-solid fa-ticket"></i>
                    </div>
                    
                    <div>
                        <div class="flex items-center gap-3 mb-1.5">
                            <span class="text-xs font-bold text-support-text bg-slate-100 px-2 py-0.5 rounded border border-slate-200">#TCK-@ticket.Id.ToString("D4")</span>
                            <span class="text-xs font-medium text-amber-600 bg-amber-50 px-2 py-0.5 rounded border border-amber-200 flex items-center gap-1">
                                <i class="fa-regular fa-clock"></i> @ticket.CreatedAt.ToString("dd MMM HH:mm")
                            </span>
                        </div>
                        <h3 class="text-lg font-bold text-support-text mb-1.5 group-hover:text-support-primary transition-colors">@ticket.Subject</h3>
                        <p class="text-sm text-support-muted line-clamp-1">@ticket.Message</p>
                    </div>
                </div>

                <div class="flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-8 border-t md:border-t-0 md:border-l border-support-border pt-4 md:pt-0 md:pl-8">
                    <div>
                        <div class="text-xs text-support-muted mb-1 uppercase font-semibold tracking-wider">Müşteri</div>
                        <div class="font-medium text-support-text text-sm flex items-center gap-2 bg-support-secondary/50 px-3 py-1.5 rounded-lg border border-support-primary/10">
                            <i class="fa-solid fa-user text-support-primary"></i> @ticket.Customer.FullName
                        </div>
                    </div>
                    
                    <button class="w-full md:w-auto bg-white border-2 border-emerald-500 text-emerald-600 hover:bg-emerald-500 hover:text-white px-6 py-2.5 rounded-xl font-bold transition-all flex items-center justify-center gap-2 shadow-sm group/btn transform hover:-translate-y-0.5">
                        <i class="fa-solid fa-check group-hover/btn:scale-125 transition-transform"></i> Sorunu Çöz
                    </button>
                </div>
            </div>
        }
    }
</div>
