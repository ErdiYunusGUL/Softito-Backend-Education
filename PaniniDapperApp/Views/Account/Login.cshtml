@{
    ViewData["Title"] = "Login";
}

<div class="glass-card p-5 shadow" style="width: 100%; max-width: 400px; margin-top: 100px;">
    <div class="text-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-hexagon-fill"></i> Sticker Market</h2>
        <p class="text-muted">Sign in to your collector account</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger p-2 text-center small">@ViewBag.Error</div>
    }

    <form asp-action="Login" method="post">
        <div class="mb-3">
            <label class="form-label text-muted small">Username</label>
            <input type="text" name="username" class="form-control form-control-lg" required />
        </div>
        <div class="mb-4">
            <label class="form-label text-muted small">Password</label>
            <input type="password" name="password" class="form-control form-control-lg" required />
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Enter Market</button>
    </form>
    
    <div class="text-center mt-4">
        <small class="text-muted">Test accounts: ali / 12345 or ayse / 12345</small>
    </div>
</div>
