@model IEnumerable<PaniniDapperApp.Models.AlbumItem>
@{
    ViewData["Title"] = "My Collection";
    var missingStickers = ViewBag.MissingStickers as IEnumerable<PaniniDapperApp.Models.Sticker>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-collection text-primary"></i> My Album</h2>
</div>

<ul class="nav nav-tabs mb-4 border-secondary" id="albumTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold" id="owned-tab" data-bs-toggle="tab" data-bs-target="#owned" type="button" role="tab">Owned (@Model.Count())</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold" id="missing-tab" data-bs-toggle="tab" data-bs-target="#missing" type="button" role="tab">Missing (@(missingStickers?.Count() ?? 0))</button>
    </li>
</ul>

<div class="tab-content" id="albumTabsContent">
    <!-- OWNED STICKERS -->
    <div class="tab-pane fade show active" id="owned" role="tabpanel">
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="glass-card h-100">
                        <div class="glass-header text-center text-primary">
                            @item.Sticker?.Team?.CountryName
                        </div>
                        <div class="card-body text-center p-4">
                            <h1 class="display-4 fw-bold text-white mb-2">#@item.Sticker?.Number</h1>
                            <h5 class="mb-0">@item.Sticker?.PlayerName</h5>
                        </div>
                        <div class="card-footer bg-transparent border-secondary p-3 text-center d-flex justify-content-between align-items-center">
                            <span class="badge bg-@(item.Quantity > 1 ? "success" : "secondary")">Qty: @item.Quantity</span>
                            @if (item.Quantity > 1)
                            {
                                <form asp-controller="Market" asp-action="ListSticker" method="post" class="m-0">
                                    <input type="hidden" name="stickerId" value="@item.StickerId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success border-2 fw-bold">Sell on Market</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (!Model.Any())
        {
            <div class="alert alert-info mt-4 glass-card border-info text-info">You don't have any stickers yet!</div>
        }
    </div>

    <!-- MISSING STICKERS -->
    <div class="tab-pane fade" id="missing" role="tabpanel">
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4 opacity-50">
            @if (missingStickers != null)
            {
                foreach (var sticker in missingStickers)
                {
                    <div class="col">
                        <div class="glass-card h-100" style="border: 2px dashed var(--border-color);">
                            <div class="glass-header text-center text-muted">
                                @sticker.Team?.CountryName
                            </div>
                            <div class="card-body text-center p-4">
                                <h1 class="display-4 fw-bold text-muted mb-2">#@sticker.Number</h1>
                                <h5 class="mb-0 text-muted">@sticker.PlayerName</h5>
                            </div>
                            <div class="card-footer bg-transparent border-secondary p-3 text-center">
                                <span class="badge bg-danger">Missing</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
