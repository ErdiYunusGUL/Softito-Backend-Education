@model string
@{
    ViewData["Title"] = "Booking Successful";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6 text-center">
        <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-check-circle-fill text-success" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
        </div>
        <h1 class="display-4 text-success mb-3">Booking Confirmed!</h1>
        <p class="lead mb-4">Your flight has been successfully booked.</p>
        
        <div class="card bg-light border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="text-muted mb-2">Your PNR Code</h5>
                <h2 class="fw-bold text-primary tracking-wider">@Model</h2>
                <p class="small text-muted mt-2 mb-0">Please keep this code for your records.</p>
            </div>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary px-4">Return Home</a>
    </div>
</div>
