<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlightSearch.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FlightSearch.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="gf-header bg-white">
        <div class="container-fluid py-2 px-4 d-flex align-items-center">
            <a class="gf-logo-text d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-airplane-fill text-primary fs-3 me-2"></i>
                <span class="text-primary fs-4 fw-bold me-2">Flight</span>Search
            </a>
            <div class="ms-auto d-flex align-items-center">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">
                        <a href="#" class="btn btn-outline-primary me-2 rounded-pill px-4 dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item text-primary" href="/Admin"><i class="bi bi-shield-lock me-2"></i>Admin Panel</a></li>
                                <li><hr class="dropdown-divider"></li>
                            }
                            <li><a class="dropdown-item" href="#"><i class="bi bi-bag-check me-2"></i>My Bookings</a></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary me-2 rounded-pill px-4">Sign In</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-primary rounded-pill px-4">Register</a>
                }
            </div>
        </div>
    </header>
    <div class="container-fluid p-0">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-5">
        <div class="container py-4 text-center">
            &copy; 2026 - FlightSearch.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
