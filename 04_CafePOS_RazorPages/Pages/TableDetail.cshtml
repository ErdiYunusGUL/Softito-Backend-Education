@page "{id:int}"
@model TableDetailModel
@{
    ViewData["Title"] = Model.Table.Name;
    var totalAmount = Model.Table.Orders.Sum(o => o.Quantity * o.Product?.Price ?? 0);
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">@Model.Table.Name Detayları</h1>
        <p class="mt-1 text-sm text-gray-500">Adisyon yönetimi ve sipariş ekleme</p>
    </div>
    <a asp-page="/Index" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-colors">
        &larr; Masalara Dön
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Sol Panel: Adisyon -->
    <div class="lg:col-span-1">
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100 sticky top-6">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h2 class="text-lg font-bold text-gray-800 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Mevcut Adisyon
                </h2>
            </div>
            
            <div class="p-6">
                @if (Model.Table.Orders.Any())
                {
                    <ul class="divide-y divide-gray-100">
                        @foreach (var order in Model.Table.Orders)
                        {
                            <li class="py-3 flex justify-between items-center">
                                <div>
                                    <p class="text-sm font-medium text-gray-900">@order.Product?.Name</p>
                                    <p class="text-xs text-gray-500">@order.Quantity x @order.Product?.Price.ToString("C2")</p>
                                </div>
                                <span class="text-sm font-bold text-gray-700">@((order.Quantity * order.Product?.Price ?? 0).ToString("C2"))</span>
                            </li>
                        }
                    </ul>
                    
                    <div class="mt-6 pt-4 border-t border-gray-200">
                        <div class="flex justify-between items-center mb-6">
                            <span class="text-base font-semibold text-gray-600">Toplam Tutar:</span>
                            <span class="text-2xl font-bold text-orange-600">@totalAmount.ToString("C2")</span>
                        </div>
                        
                        <form method="post" asp-page-handler="Pay">
                            <input type="hidden" name="tableId" value="@Model.Table.Id" />
                            <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all">
                                Hesabı Kapat (Ödendi)
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="text-center py-8">
                        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                        <p class="mt-4 text-sm text-gray-500">Bu masa için henüz sipariş bulunmuyor.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sağ Panel: Ürünler -->
    <div class="lg:col-span-2">
        <div class="bg-white shadow-xl rounded-2xl p-6 border border-gray-100">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold text-gray-900">Menüden Sipariş Ekle</h2>
            </div>
            
            <form method="post" asp-page-handler="AddProduct">
                <input type="hidden" name="tableId" value="@Model.Table.Id" />
                
                @if (!Model.Table.IsOccupied)
                {
                    <div class="mb-6 bg-orange-50 rounded-xl p-4 border border-orange-100">
                        <label class="block text-sm font-semibold text-orange-800 mb-2">Masayı Açan Müşteri (Opsiyonel)</label>
                        <input type="text" name="customerName" placeholder="Örn: Ahmet Yılmaz" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-500 focus:ring-orange-500 sm:text-sm px-4 py-2 border" />
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.Table.CustomerName))
                {
                    <div class="mb-6 bg-gray-50 rounded-xl p-4 border border-gray-200 flex items-center">
                        <svg class="w-5 h-5 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        <span class="text-sm font-semibold text-gray-700">Müşteri: @Model.Table.CustomerName</span>
                    </div>
                }

                <div class="space-y-8">
                    @foreach (var category in Model.Categories)
                    {
                        <div>
                            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2 mb-4">@category.Name</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                @foreach (var product in category.Products)
                                {
                                    <div class="relative bg-gray-50 rounded-xl p-4 border border-gray-200 hover:border-orange-300 hover:shadow-md transition-all group flex justify-between items-center">
                                        <div>
                                            <p class="font-bold text-gray-900">@product.Name</p>
                                            <p class="text-orange-600 font-semibold mt-1">@product.Price.ToString("C2")</p>
                                        </div>
                                        <button type="submit" name="productId" value="@product.Id" class="bg-white text-orange-600 hover:bg-orange-600 hover:text-white border border-orange-200 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors shadow-sm group-hover:border-transparent">
                                            Ekle
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
