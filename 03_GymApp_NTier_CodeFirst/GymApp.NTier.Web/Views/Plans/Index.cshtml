@model IEnumerable<GymApp.NTier.Core.Models.Plan>

@{
    ViewData["Title"] = "Subscription Plans";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="fw-bold text-light"><span class="text-danger">📋</span> Subscription Plans</h2>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var plan in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card bg-secondary shadow border-danger border-top border-3 text-center transition-hover">
                    <div class="card-body py-5">
                        <h3 class="card-title text-light fw-bold">@plan.Name</h3>
                        <h2 class="display-5 text-danger fw-bold my-4">$@plan.Price</h2>
                        <p class="text-muted">Duration: @plan.DurationInMonths Months</p>
                        <button class="btn btn-outline-danger mt-3 w-100" disabled>Select Plan</button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted mt-5">
            <h5>No plans found in the database.</h5>
        </div>
    }
</div>
