@model AutoService_Mvc_Identity_Ajax.Models.ServiceRecord

@{
    ViewData["Title"] = "Servis Detayları";
}

<div class="row">
    <!-- Araç Bilgileri -->
    <div class="col-md-4">
        <div class="card mb-4 shadow-sm border-0">
            <div class="card-header bg-dark text-white rounded-top">
                <h5 class="mb-0"><i class="fa-solid fa-car"></i> Araç Bilgileri</h5>
            </div>
            <div class="card-body">
                <h2 class="text-center mb-4"><span class="badge bg-primary px-4 py-2 border border-2 border-white shadow-sm">@Model.LicensePlate</span></h2>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-solid fa-industry me-2"></i>Marka</span>
                        <strong class="text-dark">@Model.CarModel?.Brand?.Name</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-solid fa-car-side me-2"></i>Model</span>
                        <strong class="text-dark">@Model.CarModel?.Name</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted"><i class="fa-regular fa-calendar me-2"></i>Giriş Tarihi</span>
                        <strong class="text-dark">@Model.EntryDate.ToString("dd.MM.yyyy HH:mm")</strong>
                    </li>
                </ul>
                <div class="mt-3 p-3 bg-light rounded border border-light">
                    <label class="form-label text-muted small mb-1 fw-bold">Müşteri Şikayeti / Arıza Özeti</label>
                    <p class="mb-0 text-dark">@Model.FaultDescription</p>
                </div>
            </div>
        </div>
    </div>

    <!-- İşlemler ve Parçalar -->
    <div class="col-md-8">
        
        <!-- Tabs -->
        <ul class="nav nav-pills mb-3 shadow-sm p-1 bg-white rounded" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active rounded" id="pills-labor-tab" data-bs-toggle="pill" data-bs-target="#pills-labor" type="button" role="tab" aria-selected="true"><i class="fa-solid fa-wrench me-2"></i>İşçilikler / Hizmetler</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded" id="pills-parts-tab" data-bs-toggle="pill" data-bs-target="#pills-parts" type="button" role="tab" aria-selected="false"><i class="fa-solid fa-boxes-stacked me-2"></i>Kullanılan Parçalar</button>
            </li>
        </ul>

        <div class="tab-content" id="pills-tabContent">
            
            <!-- İşçilik Tabı -->
            <div class="tab-pane fade show active" id="pills-labor" role="tabpanel" tabindex="0">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <!-- İşlem Ekleme Formu -->
                        <form id="actionForm" class="row g-3 mb-4 bg-light p-3 rounded border border-light shadow-sm">
                            <input type="hidden" id="ServiceRecordId" value="@Model.Id" />
                            <div class="col-md-7">
                                <label class="form-label text-muted small fw-bold">Yapılan İşlem (İşçilik vb.)</label>
                                <input type="text" class="form-control" id="ActionName" placeholder="Örn: Balata Değişimi İşçiliği" required />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label text-muted small fw-bold">İşçilik Ücreti (TL)</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control" id="Price" required />
                                    <button type="submit" class="btn btn-primary" id="btnAddAction"><i class="fa-solid fa-plus"></i> Ekle</button>
                                </div>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="actionsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>İşlem Adı</th>
                                        <th class="text-end" width="150">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var action in Model.ServiceActions)
                                    {
                                        <tr>
                                            <td>@action.ActionName</td>
                                            <td class="text-end fw-medium">@action.Price.ToString("N2") ₺</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Parça Tabı -->
            <div class="tab-pane fade" id="pills-parts" role="tabpanel" tabindex="0">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <!-- Parça Ekleme Formu -->
                        <form id="partForm" class="row g-3 mb-4 bg-light p-3 rounded border border-light shadow-sm">
                            <input type="hidden" id="ServiceRecordIdForPart" value="@Model.Id" />
                            <div class="col-md-7">
                                <label class="form-label text-muted small fw-bold">Yedek Parça Seçin</label>
                                <select class="form-select" id="PartId" required>
                                    <option value="">-- Yükleniyor --</option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label text-muted small fw-bold">Miktar</label>
                                <div class="input-group">
                                    <input type="number" step="1" min="1" value="1" class="form-control" id="PartQuantity" required />
                                    <button type="submit" class="btn btn-success" id="btnAddPart"><i class="fa-solid fa-plus"></i> Ekle</button>
                                </div>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="partsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Parça Adı</th>
                                        <th class="text-center">Miktar</th>
                                        <th class="text-end">Birim Fiyat</th>
                                        <th class="text-end">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in Model.ServiceParts)
                                    {
                                        <tr>
                                            <td>@part.Part?.Name <span class="badge bg-secondary ms-1" style="font-size:0.6rem">@part.Part?.PartCode</span></td>
                                            <td class="text-center">@part.Quantity</td>
                                            <td class="text-end">@part.UnitPrice.ToString("N2") ₺</td>
                                            <td class="text-end fw-bold">@((part.Quantity * part.UnitPrice).ToString("N2")) ₺</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>

        <!-- Genel Toplam Özeti -->
        <div class="card shadow-sm border-0 mt-4 bg-primary text-white bg-gradient">
            <div class="card-body d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fa-solid fa-calculator me-2"></i>Genel Toplam Tutar</h5>
                <h3 class="mb-0 fw-bold" id="grandTotal">
                    @((Model.ServiceActions.Sum(x => x.Price) + Model.ServiceParts.Sum(p => p.Quantity * p.UnitPrice)).ToString("N2")) ₺
                </h3>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            
            // --- Yedek Parçaları Dropdown'a Yükle ---
            function loadParts() {
                var select = $("#PartId");
                select.html('<option value="">-- Yükleniyor --</option>');
                
                $.ajax({
                    url: '@Url.Action("GetAvailableParts", "Parts")',
                    type: 'GET',
                    success: function (data) {
                        select.empty();
                        if(data.length > 0) {
                            select.append('<option value="">-- Parça Seçiniz --</option>');
                            $.each(data, function (index, item) {
                                select.append($('<option></option>')
                                    .val(item.id)
                                    .text(item.name + ' (' + item.partCode + ') - Stok: ' + item.stockQuantity + ' - Fiyat: ' + item.unitPrice + ' ₺')
                                );
                            });
                        } else {
                            select.append('<option value="">Stokta parça yok</option>');
                        }
                    }
                });
            }
            loadParts();

            // --- İşçilik Ekleme (AJAX) ---
            $("#actionForm").submit(function(e) {
                e.preventDefault();
                var btn = $("#btnAddAction");
                var recordId = $("#ServiceRecordId").val();
                var actionName = $("#ActionName").val();
                var price = $("#Price").val();

                btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');

                $.ajax({
                    url: '@Url.Action("AddAction", "ServiceRecords")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ ServiceRecordId: parseInt(recordId), ActionName: actionName, Price: parseFloat(price) }),
                    success: function (res) {
                        if (res.success) {
                            $("#actionsTable tbody").append(`<tr><td>${res.data.actionName}</td><td class="text-end fw-medium">${res.data.price} ₺</td></tr>`);
                            updateGrandTotal();
                            $("#ActionName").val(''); $("#Price").val('');
                            Swal.fire({ icon: 'success', title: 'İşçilik eklendi', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
                        } else {
                            Swal.fire('Hata!', res.message, 'error');
                        }
                    },
                    complete: function() { btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> Ekle'); }
                });
            });

            // --- Parça Ekleme (AJAX) ---
            $("#partForm").submit(function(e) {
                e.preventDefault();
                var btn = $("#btnAddPart");
                var recordId = $("#ServiceRecordIdForPart").val();
                var partId = $("#PartId").val();
                var qty = $("#PartQuantity").val();

                if(!partId) return;

                btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');

                $.ajax({
                    url: '@Url.Action("AddPart", "ServiceRecords")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ ServiceRecordId: parseInt(recordId), PartId: parseInt(partId), Quantity: parseInt(qty) }),
                    success: function (res) {
                        if (res.success) {
                            $("#partsTable tbody").append(`
                                <tr>
                                    <td>${res.data.partName} <span class="badge bg-success ms-1" style="font-size:0.6rem">Yeni</span></td>
                                    <td class="text-center">${res.data.quantity}</td>
                                    <td class="text-end">${res.data.unitPrice} ₺</td>
                                    <td class="text-end fw-bold">${res.data.totalPrice} ₺</td>
                                </tr>
                            `);
                            updateGrandTotal();
                            $("#PartId").val(''); $("#PartQuantity").val('1');
                            loadParts(); // Stok güncellendiği için dropdown'ı yeniden yükle
                            Swal.fire({ icon: 'success', title: 'Parça eklendi ve stoktan düşüldü', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
                        } else {
                            Swal.fire('Hata!', res.message, 'error');
                        }
                    },
                    complete: function() { btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> Ekle'); }
                });
            });

            // --- Genel Toplam Güncelleme ---
            function updateGrandTotal() {
                var total = 0;
                // İşçilikleri topla
                $("#actionsTable tbody tr").each(function() {
                    var val = parseFloat($(this).find("td:eq(1)").text().replace(' ₺', '').replace(/\./g, '').replace(',', '.'));
                    if(!isNaN(val)) total += val;
                });
                // Parçaları topla (Son kolon: Toplam)
                $("#partsTable tbody tr").each(function() {
                    var val = parseFloat($(this).find("td:eq(3)").text().replace(' ₺', '').replace(/\./g, '').replace(',', '.'));
                    if(!isNaN(val)) total += val;
                });
                
                var formatter = new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                $("#grandTotal").text(formatter.format(total) + " ₺");
            }
        });
    </script>
}
