@model IEnumerable<AdvancedGameStore.Models.SystemLog>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-8">
    <h2 class="text-2xl font-bold text-white mb-2">Genel Bakış</h2>
    <p class="text-slate-400">Mağazanızın güncel durumunu buradan takip edebilirsiniz.</p>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Card 1 -->
    <div class="bg-corporate-surface border border-corporate-border rounded-xl p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-slate-400 font-medium">Toplam Sipariş</h3>
            <div class="w-10 h-10 rounded-full bg-blue-500/10 text-blue-500 flex items-center justify-center text-lg">
                <i class="fa-solid fa-shopping-cart"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-white mb-2">@ViewBag.TotalOrders</div>
        <div class="text-sm text-emerald-400 flex items-center"><i class="fa-solid fa-arrow-up mr-1"></i> %12 geçen aya göre</div>
    </div>
    
    <!-- Card 2 -->
    <div class="bg-corporate-surface border border-corporate-border rounded-xl p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-slate-400 font-medium">Toplam Ciro</h3>
            <div class="w-10 h-10 rounded-full bg-emerald-500/10 text-emerald-500 flex items-center justify-center text-lg">
                <i class="fa-solid fa-wallet"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-white mb-2">@(((decimal)ViewBag.TotalRevenue).ToString("C2"))</div>
        <div class="text-sm text-emerald-400 flex items-center"><i class="fa-solid fa-arrow-up mr-1"></i> %8 geçen aya göre</div>
    </div>

    <!-- Card 3 -->
    <div class="bg-corporate-surface border border-corporate-border rounded-xl p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-slate-400 font-medium">Aktif Müşteriler</h3>
            <div class="w-10 h-10 rounded-full bg-purple-500/10 text-purple-500 flex items-center justify-center text-lg">
                <i class="fa-solid fa-users"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-white mb-2">1,248</div>
        <div class="text-sm text-red-400 flex items-center"><i class="fa-solid fa-arrow-down mr-1"></i> %2 geçen aya göre</div>
    </div>
</div>

<!-- Recent Logs Table -->
<div class="bg-corporate-surface border border-corporate-border rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-corporate-border flex justify-between items-center bg-slate-900/30">
        <h3 class="text-lg font-bold text-white flex items-center gap-2"><i class="fa-solid fa-list-check text-corporate-primary"></i> Son Sistem Hareketleri</h3>
        <button class="text-corporate-primary hover:text-blue-400 text-sm font-medium transition-colors">Tümünü Gör</button>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-400">
            <thead class="text-xs uppercase bg-slate-900/80 text-slate-300">
                <tr>
                    <th scope="col" class="px-6 py-4 font-medium">Zaman</th>
                    <th scope="col" class="px-6 py-4 font-medium">İşlem (Action)</th>
                    <th scope="col" class="px-6 py-4 font-medium">Detaylar</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-corporate-border">
                @foreach (var log in Model)
                {
                    <tr class="hover:bg-slate-800/50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">@log.Timestamp.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="px-6 py-4">
                            <span class="bg-slate-700/50 border border-slate-600 text-slate-300 px-3 py-1 rounded-md text-xs font-medium">@log.Action</span>
                        </td>
                        <td class="px-6 py-4 text-slate-300">@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
