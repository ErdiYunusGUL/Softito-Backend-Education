@model DartLeague.CodeFirst.Models.Match
@{ ViewData["Title"] = "Add Match"; }

<div class="glass-card w-50 mx-auto mt-4">
    <h3 class="text-primary mb-3">Add New Fixture</h3>
    <form asp-action="Create">
        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="MatchDate" class="control-label">Date & Time</label>
                <input asp-for="MatchDate" class="form-control" type="datetime-local" required />
            </div>
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Week" class="control-label">League Week</label>
                <input asp-for="Week" class="form-control" type="number" min="1" max="50" required />
            </div>
        </div>
        <div class="form-group mb-3">
            <label asp-for="VenueId" class="control-label">Venue</label>
            <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId"></select>
        </div>
        <div class="row">
            <div class="col-6 form-group mb-3">
                <label asp-for="HomeTeamId" class="control-label">Home Team</label>
                <select asp-for="HomeTeamId" class="form-select" asp-items="ViewBag.HomeTeamId"></select>
            </div>
            <div class="col-6 form-group mb-3">
                <label asp-for="AwayTeamId" class="control-label">Away Team</label>
                <select asp-for="AwayTeamId" class="form-select" asp-items="ViewBag.AwayTeamId"></select>
            </div>
        </div>
        
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save Fixture</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">Cancel</a>
        </div>
    </form>
</div>
