@model DartLeague.CodeFirst.Models.Match
@{ ViewData["Title"] = "Edit Match"; }

<div class="glass-card w-50 mx-auto mt-4">
    <h3 class="text-warning mb-3">Edit Fixture & Score</h3>
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        
        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="MatchDate" class="control-label">Date & Time</label>
                <input asp-for="MatchDate" class="form-control" type="datetime-local" required />
            </div>
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Week" class="control-label">League Week</label>
                <input asp-for="Week" class="form-control" type="number" min="1" max="50" required />
            </div>
        </div>
        
        <div class="form-group mb-3">
            <label asp-for="VenueId" class="control-label">Venue</label>
            <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId"></select>
        </div>
        
        <div class="row">
            <div class="col-6 form-group mb-3">
                <label asp-for="HomeTeamId" class="control-label">Home Team</label>
                <select asp-for="HomeTeamId" class="form-select" asp-items="ViewBag.HomeTeamId"></select>
            </div>
            <div class="col-6 form-group mb-3">
                <label asp-for="AwayTeamId" class="control-label">Away Team</label>
                <select asp-for="AwayTeamId" class="form-select" asp-items="ViewBag.AwayTeamId"></select>
            </div>
        </div>

        <hr class="border-secondary my-4" />
        <h5 class="text-info">Match Result</h5>

        <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" asp-for="IsPlayed">
            <label class="form-check-label" asp-for="IsPlayed">Match is played?</label>
        </div>

        <div class="row">
            <div class="col-6 form-group mb-3">
                <label asp-for="HomeTeamScore" class="control-label">Home Score</label>
                <input asp-for="HomeTeamScore" class="form-control" type="number" min="0" max="12" />
            </div>
            <div class="col-6 form-group mb-3">
                <label asp-for="AwayTeamScore" class="control-label">Away Score</label>
                <input asp-for="AwayTeamScore" class="form-control" type="number" min="0" max="12" />
            </div>
        </div>
        <div class="form-text text-light opacity-75 mb-3"><i class="bi bi-info-circle"></i> Max total score is 12 (6 Singles x 1pt + 3 Doubles x 2pts). Winner gets 3 league points.</div>
        
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning">Update Fixture</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">Cancel</a>
        </div>
    </form>
</div>
