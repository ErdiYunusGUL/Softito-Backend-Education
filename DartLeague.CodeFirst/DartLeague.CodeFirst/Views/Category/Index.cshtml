@model IEnumerable<DartLeague.CodeFirst.Models.Category>
@{ ViewData["Title"] = "Categories"; }

<div class="glass-card mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary"><i class="bi bi-tags-fill"></i> Categories</h2>
        @if (User.IsInRole("Admin")) {
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Category</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Category Name</th>
                    @if (User.IsInRole("Admin")) {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="fw-bold fs-5">@item.Name</td>
                        @if (User.IsInRole("Admin")) {
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?');">Delete</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
