@model DartLeague.CodeFirst.Models.Category
@{ ViewData["Title"] = "Add Category"; }

<div class="glass-card w-50 mx-auto mt-4">
    <h3 class="text-primary mb-3">Add New Category</h3>
    <form asp-action="Create">
        <div class="form-group mb-4">
            <label asp-for="Name" class="control-label">Category Name</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div>
            <button type="submit" class="btn btn-primary">Save Category</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">Cancel</a>
        </div>
    </form>
</div>
