@model AutoService_Mvc_Identity_Ajax.Models.Part

@{
    ViewData["Title"] = "Yeni Parça Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-box-open text-primary me-2"></i> Yeni Yedek Parça Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-medium"></label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Yağ Filtresi" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PartCode" class="form-label fw-medium"></label>
                            <input asp-for="PartCode" class="form-control" placeholder="Örn: FLT-001" style="text-transform: uppercase;" />
                            <span asp-validation-for="PartCode" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="StockQuantity" class="form-label fw-medium"></label>
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UnitPrice" class="form-label fw-medium"></label>
                            <div class="input-group">
                                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">₺</span>
                            </div>
                            <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between pt-2 border-top">
                        <a asp-action="Index" class="btn btn-light px-4">İptal</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
