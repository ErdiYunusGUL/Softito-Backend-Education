@model IEnumerable<AutoService_Mvc_Identity_Ajax.Models.ServiceRecord>

@{
    ViewData["Title"] = "Servis Kayıtları";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Tüm Servis Kayıtları</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus"></i> Yeni Kayıt
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Plaka</th>
                        <th>Marka / Model</th>
                        <th>Arıza</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EntryDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="badge bg-dark">@item.LicensePlate</span></td>
                            <td>@item.CarModel?.Brand?.Name / @item.CarModel?.Name</td>
                            <td class="text-truncate" style="max-width: 250px;">@item.FaultDescription</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    <i class="fa-solid fa-eye"></i> Detay
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Kayıt bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
